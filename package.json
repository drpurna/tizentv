{
  "name": "Tizen TV",
  "version": "1.0.3",
  "description": "Smart IPTV player module for Samsung Tizen TVs via TizenBrew",
  "license": "MIT",
  "files": [
    "app",
    "service.js",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "tizen",
    "tizenbrew",
    "iptv",
    "m3u",
    "hls",
    "samsung-tv"
  ],
  "packageType": "app",
  "appName": "Tizen TV",
  "appPath": "app/index.html",
  "keys": [
    "MediaPlay",
    "MediaPause",
    "MediaPlayPause",
    "MediaStop",
    "MediaFastForward",
    "MediaRewind",
    "ChannelUp",
    "ChannelDown",
    "ColorF0Red",
    "ColorF1Green",
    "ColorF2Yellow",
    "ColorF3Blue"
  ],
  "serviceFile": "service.js",
  "evaluateScriptOnDocumentStart": false
}